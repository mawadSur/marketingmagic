# Supabase (project: marketingmagic — create a separate project from pitch-pit)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=service-role-key

# Anthropic — used by plan generation in lib/plan/
ANTHROPIC_API_KEY=sk-ant-...

# Vercel Cron auth — generate with: openssl rand -hex 32
CRON_SECRET=

# Webhook ingestion signing secret — workspaces send X-Signature with their payloads.
# Per-workspace secrets are stored in workspaces.webhook_secret (added in a later migration).
# This top-level value is used during dev / for the demo workspace.
WEBHOOK_DEV_SECRET=

# Public canonical URL — used by callbacks and OG metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Channel-specific app credentials ────────────────────────────────────
# These are the marketingmagic platform's own developer-app credentials.
# Per-workspace user credentials live in social_accounts.credentials (DB).

# X (Twitter) — only needed for the OAuth flow when adding a workspace's
# X account. For V0 manual-paste flow, leave unset.
# X_CLIENT_ID=
# X_CLIENT_SECRET=

# Meta (IG/FB/Threads) — V1.5+
# META_APP_ID=
# META_APP_SECRET=

# Bluesky has no app-level creds (workspaces use their own app passwords).

# LinkedIn — V3 (after partner approval)
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=

# ─── Video pipeline (MoneyPrinterTurbo BYO render + multi-channel publishing) ──
# MoneyPrinterTurbo render worker. Deploy the MPT container (see its render.yaml)
# and point MPT_BASE_URL at it. MPT_API_TOKEN MUST equal the worker's MPT_API_KEY.
# Leave both unset to cleanly disable all video features.
MPT_BASE_URL=
MPT_API_TOKEN=
# AES-256-GCM key encrypting customers' BYO LLM/Pexels keys at rest. Must decode
# to 32 bytes (64 hex chars OR base64). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: rotating this makes already-stored BYO keys undecryptable.
BYO_ENCRYPTION_KEY=
# Comma-separated channels allowed to PUBLISH video. Others build/connect but
# refuse to publish video until their gate clears (X = media.write re-auth;
# IG / LinkedIn-org / TikTok = app review/audit).
VIDEO_PUBLISH_CHANNELS=bluesky,facebook,threads
# TikTok Content Posting API (optional). NOTE: client_KEY, not client_id.
# Stays SELF_ONLY/sandbox until TikTok audits the app; only add `tiktok` to
# VIDEO_PUBLISH_CHANNELS once audited.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
