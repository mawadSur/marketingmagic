# Supabase (project: marketingmagic — create a separate project from pitch-pit)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=service-role-key

# Anthropic — used by plan generation in lib/plan/
ANTHROPIC_API_KEY=sk-ant-...

# Vercel Cron auth — generate with: openssl rand -hex 32
CRON_SECRET=

# Webhook ingestion signing secret — workspaces send X-Signature with their payloads.
# Per-workspace secrets are stored in workspaces.webhook_secret (added in a later migration).
# This top-level value is used during dev / for the demo workspace.
WEBHOOK_DEV_SECRET=

# Public canonical URL — used by callbacks and OG metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Channel-specific app credentials ────────────────────────────────────
# These are the marketingmagic platform's own developer-app credentials.
# Per-workspace user credentials live in social_accounts.credentials (DB).

# X (Twitter) — only needed for the OAuth flow when adding a workspace's
# X account. For V0 manual-paste flow, leave unset.
# X_CLIENT_ID=
# X_CLIENT_SECRET=

# Meta (IG/FB/Threads) — V1.5+
# META_APP_ID=
# META_APP_SECRET=

# Bluesky has no app-level creds (workspaces use their own app passwords).

# LinkedIn — V3 (after partner approval)
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
