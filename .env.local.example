# Source of truth for env vars is src/lib/env.ts. Keep this file in sync when
# you add or change a zod constraint there. Constraints noted inline so a fresh
# clone doesn't trip on a "too short" or "invalid url" boot error.

# ─── Required ────────────────────────────────────────────────────────────
# Build & boot fail if these are unset or fail validation.

# Supabase (create a dedicated project for marketingmagic)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co   # required, URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key                 # required, min 1
SUPABASE_SERVICE_ROLE_KEY=service-role-key                  # required, min 1

# Anthropic — Claude API, drives plan/voice/explainer generation.
ANTHROPIC_API_KEY=sk-ant-...                                # required, min 1

# Cron auth — signs every GitHub-Actions cron POST. Generate with:
#   openssl rand -hex 32
CRON_SECRET=                                                # required, min 16

# ─── Public site URL ─────────────────────────────────────────────────────
# Optional. When unset, siteUrl() falls back to VERCEL_PROJECT_PRODUCTION_URL,
# then VERCEL_URL, then http://localhost:3000. Set explicitly for custom
# domains and OAuth redirect URIs that must match a registered value.
NEXT_PUBLIC_SITE_URL=http://localhost:3000                  # optional, URL

# ─── Webhook ingestion ───────────────────────────────────────────────────
# Used for the demo workspace during dev. Per-workspace secrets live in
# workspaces.webhook_secret.
WEBHOOK_DEV_SECRET=                                         # optional, min 8

# ─── Channel app credentials ─────────────────────────────────────────────
# Per-workspace user creds live in social_accounts.credentials. These are the
# platform-level developer apps. All optional — when a channel's app creds
# are missing, its connect UI hides and OAuth routes redirect with a clear
# "<channel>_not_configured" error instead of crashing.

# X (Twitter)
X_CLIENT_ID=                                                # optional
X_CLIENT_SECRET=                                            # optional

# LinkedIn
LINKEDIN_CLIENT_ID=                                         # optional
LINKEDIN_CLIENT_SECRET=                                     # optional

# Meta — split per product so each channel ships under its own app review.
# META_APP_ID/SECRET = umbrella app (data-deletion callback, future FB Page).
# META_FB_LOGIN_CONFIG_ID = Facebook Login for Business "Configuration ID"
# (FLB sends config_id in place of scope=; required for Facebook channel).
META_APP_ID=                                                # optional
META_APP_SECRET=                                            # optional
META_FB_LOGIN_CONFIG_ID=                                    # optional
INSTAGRAM_APP_ID=                                           # optional
INSTAGRAM_APP_SECRET=                                       # optional
THREADS_APP_ID=                                             # optional
THREADS_APP_SECRET=                                         # optional

# TikTok — Content Posting API (OAuth 2.0 PKCE + chunked video publish).
# ⚠️ TikTok calls the public identifier "client KEY", not "client id". Do not
# rename to *_CLIENT_ID — the OAuth endpoints reject client_id.
TIKTOK_CLIENT_KEY=                                          # optional
TIKTOK_CLIENT_SECRET=                                       # optional

# Bluesky uses per-workspace app passwords; no platform-level creds.

# ─── Email (Resend) ──────────────────────────────────────────────────────
# Daily approval digest + magic-link approve/reject. When RESEND_API_KEY is
# unset, the digest route logs and skips instead of throwing.
RESEND_API_KEY=                                             # optional, min 8
EMAIL_LINK_SECRET=                                          # optional, min 32 (HMAC key for magic links)
EMAIL_FROM=                                                 # optional (default: "marketingmagic <noreply@marketingmagic.app>")

# ─── Stripe billing ──────────────────────────────────────────────────────
# All optional — app boots without billing (Hobby tier is the DB default).
# stripeClient() throws a clear error at the call site when SECRET_KEY is
# missing, and unsold tiers just hide their upgrade affordance.
STRIPE_SECRET_KEY=                                          # optional, min 8
STRIPE_WEBHOOK_SECRET=                                      # optional, min 8
STRIPE_PRICE_PRO=                                           # optional, min 4 (Stripe price id)
STRIPE_PRICE_AGENCY=                                        # optional, min 4
STRIPE_PRICE_FOUNDER=                                       # optional, min 4 (Phase 2.6 tier)

# ─── Discord integration (Phase 4.7) ─────────────────────────────────────
# All optional. CLIENT_ID/SECRET drive the bot install OAuth2 flow,
# PUBLIC_KEY verifies Ed25519 signatures on interaction webhooks, BOT_TOKEN
# authenticates outbound REST calls. Treat BOT_TOKEN as high-blast-radius.
DISCORD_CLIENT_ID=                                          # optional, min 4
DISCORD_CLIENT_SECRET=                                      # optional, min 8
DISCORD_PUBLIC_KEY=                                         # optional, min 32
DISCORD_BOT_TOKEN=                                          # optional, min 16

# ─── Source ingestion (Groq Whisper) ─────────────────────────────────────
# Audio/video transcription for source ingestion. When unset, audio paths
# short-circuit with "transcription unavailable"; HTML/PDF/paste still work.
# Free key: https://console.groq.com/keys
GROQ_API_KEY=                                               # optional, min 8

# ─── Image generation (fal.ai) ───────────────────────────────────────────
# Image features short-circuit with a clear error when missing.
FAL_API_KEY=                                                # optional, min 8
FAL_DEFAULT_MODEL=fal-ai/flux/schnell                       # optional (default shown)

# ─── Video pipeline — MoneyPrinterTurbo BYO render worker ────────────────
# Deploy services/mpt-worker/ (see render.yaml) and point MPT_BASE_URL at it.
# MPT_API_TOKEN must equal the worker's MPT_API_KEY. Both unset = video
# cleanly disabled (mptConfigured() === false).
MPT_BASE_URL=                                               # optional, URL
MPT_API_TOKEN=                                              # optional, min 8

# AES-256-GCM key encrypting customers' BYO LLM/Pexels keys at rest. Must
# decode to 32 bytes (64 hex or 44 base64). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: rotating this makes already-stored BYO keys undecryptable.
BYO_ENCRYPTION_KEY=                                         # optional, min 32

# Comma-separated allowlist of channels permitted to publish video. Code
# ships for every channel but only listed ones publish; the rest throw
# "video publishing not yet enabled" in dispatch's video branch. Default
# (when unset) is the 3 channels that need no new app-review grant.
VIDEO_PUBLISH_CHANNELS=bluesky,facebook,threads             # optional (default shown)

# ─── Reference-image video (bet ④, SPIKE) ────────────────────────────────
# Master kill-switch for the image-conditioned / talking-avatar path
# (distinct from MPT Pexels-stitch). Off by default; the provider stub
# throws and the upload UI renders "not yet enabled" until flipped to
# 1/true. BYO provider keys (D-ID, HeyGen, Higgsfield, fal) live in
# workspace_byo_keys per-workspace, not in env.
REFERENCE_VIDEO_ENABLED=                                    # optional, "1" or "true" to enable
REFERENCE_VIDEO_FAL_MODEL=fal-ai/kling-video/v1.6/standard/image-to-video  # optional (default shown)

# D-ID talking-avatar (Capability B — "Make it talk")
DID_BASE_URL=https://api.d-id.com                           # optional (default shown)
DID_DEFAULT_VOICE_ID=en-US-JennyNeural                      # optional (default Microsoft TTS voice)

# HeyGen talking-avatar (second 'present' provider, alongside D-ID)
HEYGEN_BASE_URL=https://api.heygen.com                      # optional (default shown)
HEYGEN_DEFAULT_VOICE_ID=                                    # optional (empty by default; HeyGen voice ids are opaque)

# Higgsfield UGC avatar
HIGGSFIELD_BASE_URL=https://platform.higgsfield.ai          # optional (default shown)
HIGGSFIELD_MODEL=higgsfield-ugc-avatar                      # optional (default shown)
